{
  "name": "recipe-aggregator",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:shared": "npm run build -w packages/shared",
    "dev:web": "npm run dev -w packages/web",
    "build:web": "npm run build -w packages/web",
    "dev:extension": "npm run dev -w packages/extension",
    "build:extension": "npm run build -w packages/extension",
    "typecheck": "tsc --noEmit -p packages/shared/tsconfig.json"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  }
}
