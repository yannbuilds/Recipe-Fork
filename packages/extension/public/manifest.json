{
  "manifest_version": 3,
  "name": "Pie Keeper",
  "version": "2.3.0",
  "description": "Save recipes from any website with AI-powered parsing",
  "permissions": ["activeTab", "storage", "identity", "cookies", "scripting"],
  "host_permissions": ["https://piekeeper.com/*", "https://*.piekeeper.com/*"],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Pie Keeper"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
