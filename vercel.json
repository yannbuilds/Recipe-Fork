{
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/workbox-(.*)js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/landing",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/:path((?!privacy|_next|assets|screenshots|favicon).+)",
      "has": [{ "type": "host", "value": "piekeeper.com" }],
      "destination": "https://app.piekeeper.com/:path",
      "permanent": false
    },
    {
      "source": "/:path((?!privacy|_next|assets|screenshots|favicon).+)",
      "has": [{ "type": "host", "value": "www.piekeeper.com" }],
      "destination": "https://app.piekeeper.com/:path",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
